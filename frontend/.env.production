# Production Environment Variables for Vercel
# These will be overridden by Vercel environment variables

# Backend API URL - Update this with your Railway backend URL
REACT_APP_API_BASE_URL=https://your-backend.railway.app

# WebSocket URL - Update this with your Railway WebSocket URL
REACT_APP_WS_URL=wss://your-backend.railway.app

# Build optimizations
GENERATE_SOURCEMAP=false
INLINE_RUNTIME_CHUNK=false

# Disable development features
REACT_APP_NODE_ENV=production