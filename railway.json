{
  "name": "scalable-chat-platform",
  "services": [
    {
      "name": "backend",
      "source": {
        "type": "github"
      },
      "build": {
        "builder": "NIXPACKS",
        "buildCommand": "mvn clean package -DskipTests",
        "startCommand": "java -jar target/chat-platform-backend-1.0.0.jar"
      },
      "deploy": {
        "healthcheck": {
          "path": "/api/health/status",
          "timeout": 30
        },
        "port": 8080
      },
      "variables": {
        "SPRING_PROFILES_ACTIVE": "production",
        "SERVER_PORT": "8080",
        "JAVA_OPTS": "-Xms512m -Xmx1024m"
      }
    },
    {
      "name": "postgres",
      "source": {
        "type": "template",
        "template": "postgres"
      },
      "variables": {
        "POSTGRES_DB": "chatdb",
        "POSTGRES_USER": "chatuser"
      }
    },
    {
      "name": "redis",
      "source": {
        "type": "template",
        "template": "redis"
      }
    },
    {
      "name": "mongodb",
      "source": {
        "type": "template",
        "template": "mongodb"
      },
      "variables": {
        "MONGO_INITDB_DATABASE": "chatdb"
      }
    }
  ]
}